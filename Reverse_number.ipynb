   "source": [
    "## Reverse Number"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 12,
   "id": "d8aae3cf-3e01-42fc-b11a-665af787d595",
   "metadata": {},
   "outputs": [
    {
     "name": "stdin",
     "output_type": "stream",
     "text": [
      "Enter a number: 56\n"
     ]
    },
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "The Reverse Number is: 65\n"
     ]
    }
   ],
   "source": [
    "num=int(input(\"Enter a number:\"))\n",
    "def reverse(num):\n",
    "    rev=0\n",
    "    while num>0:\n",
    "        rev=rev*10+(num%10)\n",
    "        num=num//10\n",
    "    return rev\n",
    "reverse_no=reverse(num)\n",
    "print(\"The Reverse Number is:\",reverse_no)"
   ]
  },
